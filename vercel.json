{
  "version": 2,
  "functions": {
    "api/chat.js": {
      "maxDuration": 30,
      "memory": 256
    },
    "api/application.js": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
   {
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/app.html", "dest": "/app.html" },
    { "src": "/premium-application.html", "dest": "/premium-application.html" },
    { "src": "/(.*)", "dest": "/index.html" }
    ]
}
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
